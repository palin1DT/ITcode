</head>
<body>

<div class="search-box">
    <h2>MES 数据看板 - 关键词查询</h2>
    <input type="text" id="keywordInput" placeholder="输入产品 SN、工单号或站点...">
    <button onclick="startSearch()">查询</button>
</div>

<div class="results" id="resultSection">
    <h3>查询结果</h3>
    <table>
        <thead>
            <tr>
                <th>工单号</th>
